<div class="container mt-4">
  <%= link_to "← Back to all lists", lists_path, class: "btn btn-link mb-3" %>

  <h1>Create a new list</h1>

  <%= simple_form_for @list do |f| %>
    <%= f.input :name %>
    <%= f.input :photo, as: :file %>
    <%= f.button :submit, "Create List", class: "btn btn-primary" %>
  <% end %>
</div>
