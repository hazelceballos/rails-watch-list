<div class="container mt-4">
  <%= link_to "← All lists", lists_path, class: "btn btn-link mb-3" %>

  <h1 class="mb-4"><%= @list.name %></h1>

  <% if @list.photo.attached? %>
    <%= cl_image_tag @list.photo.key, height: 400, width: 1000, crop: :fill, class: "img-fluid rounded mb-4 w-100" %>
  <% end %>

  <div class="row">
    <!-- Movies column -->
    <div class="col-lg-8">
      <h3 class="mb-3">Movies</h3>
      <% if @list.movies.any? %>
        <div class="row">
          <% @list.bookmarks.each do |bookmark| %>
            <div class="col-md-4 mb-4">
              <div class="card h-100 shadow-sm">
                <img src="<%= bookmark.movie.poster_url %>" class="card-img-top" alt="<%= bookmark.movie.title %>">
                <div class="card-body">
                  <h6 class="card-title"><%= bookmark.movie.title %></h6>
                  <p class="card-text small text-muted"><%= bookmark.comment %></p>
                  <%= link_to "Remove", bookmark_path(bookmark), class: "btn btn-sm btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: "Remove this movie?" } %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted">No movies yet.</p>
      <% end %>

      <!-- Add movie form (embedded) -->
      <div class="card mt-3 mb-4">
        <div class="card-body">
          <h5 class="card-title">Add a movie</h5>
          <%= simple_form_for [@list, @bookmark] do |f| %>
            <%= f.association :movie, collection: Movie.all, label_method: :title %>
            <%= f.input :comment %>
            <%= f.button :submit, "Add to list", class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Reviews column -->
    <div class="col-lg-4">
      <h3 class="mb-3">Reviews</h3>
      <% @list.reviews.each do |review| %>
        <div class="card mb-2">
          <div class="card-body">
            <h6 class="card-subtitle mb-2 text-muted"><%= review.author %></h6>
            <p class="card-text small"><%= review.content %></p>
          </div>
        </div>
      <% end %>

      <!-- Add review form (embedded) -->
      <div class="card mt-3">
        <div class="card-body">
          <h5 class="card-title">Leave a review</h5>
          <%= simple_form_for [@list, @review] do |f| %>
            <%= f.input :author %>
            <%= f.input :content %>
            <%= f.button :submit, "Post review", class: "btn btn-primary btn-sm" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
