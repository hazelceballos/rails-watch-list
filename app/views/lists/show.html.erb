<div class="container mt-4">
  <%= link_to "← Back to all lists", lists_path, class: "btn btn-link mb-3" %>

  <h1><%= @list.name %></h1>

  <hr>

  <h3>Movies in this list</h3>

  <% if @list.movies.any? %>
    <div class="row">
      <% @list.bookmarks.each do |bookmark| %>
        <div class="col-md-3 mb-4">
          <div class="card h-100">
            <img src="<%= bookmark.movie.poster_url %>" class="card-img-top" alt="<%= bookmark.movie.title %>">
            <div class="card-body">
              <h6 class="card-title"><%= bookmark.movie.title %></h6>
              <p class="card-text small text-muted"><%= bookmark.comment %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">No movies in this list yet.</p>
  <% end %>

  <hr>
  <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-primary" %>
</div>
